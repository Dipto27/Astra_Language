-- Astra Test: Control Flow
-- ═══════════════════════════════════════════

-- If / elif / else
let score = 85

if score >= 90 {
    println("Grade: A")
} elif score >= 80 {
    println("Grade: B")
} elif score >= 70 {
    println("Grade: C")
} else {
    println("Grade: F")
}

-- While loop
mut i = 0
mut sum = 0
while i < 10 {
    sum += i
    i += 1
}
println("Sum 0..9 = " + str(sum))

-- For loop
mut total = 0
for x in range(5) {
    total += x
}
println("Sum range(5) = " + str(total))

-- For loop with list
let fruits = ["apple", "banana", "cherry"]
for fruit in fruits {
    println("Fruit: " + fruit)
}

-- Break and continue
mut found = -1
for n in range(100) {
    if n * n > 50 {
        found = n
        break
    }
}
println("First n where n*n > 50: " + str(found))

-- Continue
println("Odd numbers 0-9:")
for n in range(10) {
    if n % 2 == 0 {
        continue
    }
    println("  " + str(n))
}

-- Match statement
let day = 3
match day {
    1 => println("Monday")
    2 => println("Tuesday")
    3 => println("Wednesday")
    4 => println("Thursday")
    5 => println("Friday")
    _ => println("Weekend")
}

-- Nested loops
println("Multiplication table (1-3):")
for i in range(1, 4) {
    for j in range(1, 4) {
        println("  " + str(i) + " x " + str(j) + " = " + str(i * j))
    }
}
